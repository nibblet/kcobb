# Public site URL for auth email links (Vercel: https://your-domain.com). Optional locally; required if Supabase Site URL does not match where users complete signup.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Keith-special access emails (comma-separated). In local development,
# paul.cobb@homevestors.com is allowed automatically for testing.
# KEITH_SPECIAL_EMAILS=keith@example.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Story audio UI is off by default while we evaluate TTS providers.
# Set to true only when the story listen feature should be visible.
# NEXT_PUBLIC_ENABLE_STORY_AUDIO=false
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude API (Phase 5)
# ANTHROPIC_API_KEY=your-api-key

# ElevenLabs (step 2: premade voice; will swap to Keith's clone in step 3).
# When both are set, the Listen button uses ElevenLabs; otherwise falls back to Web Speech.
# ELEVENLABS_API_KEY=sk_...
# ELEVENLABS_VOICE_ID=uZs6JatxmZWaaC4yPR1Z
